# Database Configuration
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=market_intelligence
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend Configuration
PORT=3000
DATABASE_URL=postgres://myuser:mypassword@db:5432/market_intelligence

# Scraper Configuration
STOCK_FETCH_INTERVAL=86400
HOUSING_FETCH_INTERVAL=604800
SENTIMENT_FETCH_INTERVAL=3600
